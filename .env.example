# LLM provider keys — copy to .env (gitignored) and fill in
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model overrides (defaults set in each agent's main.py)
# TRIAGE_MODEL=gpt-4o
# THREAT_INTEL_MODEL=gpt-4o
# COMPLIANCE_MODEL=openai:gpt-4o
# Commander defaults to claude-haiku-4-5-20251001 (cheap) for cost control while
# routed through AIML. Set to claude-sonnet-4-6 to restore the premium model.
# COMMANDER_MODEL=claude-sonnet-4-6

# Optional: cost guards (defaults in each main.py). max_tokens caps per-call
# OUTPUT; recursion_limit caps per-message tool-loop turns (LangGraph agents).
# COMMANDER_MAX_TOKENS=1536
# TRIAGE_MAX_TOKENS=1024
# TRIAGE_RECURSION_LIMIT=25
# THREAT_INTEL_MAX_TOKENS=1024
# THREAT_INTEL_RECURSION_LIMIT=15

# Injector (injector/inject_alert.py): a Band USER API key + the incident room
# id let it auto-post the alert. Without them it prints a paste-ready message.
# BAND_INJECTOR_API_KEY=band_u_...
# BAND_ROOM_ID=<incident-room-uuid>      # or set room.default_room_id / pass --room
# BAND_REST_URL=https://app.thenvoi.com  # only if the platform URL changes
