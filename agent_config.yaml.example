# Band External Agent credentials — copy to agent_config.yaml (gitignored).
# Register each agent on app.band.ai → Agents → New Agent → External Agent.
# Copy the API key the FIRST time it's displayed; it cannot be retrieved later.
#
# Compliance lives under a SECOND Band account (see shared/protocol.md).
# Send a contact request from the primary account to that second account
# before launch so cross-account add_participant works.

# `handle` is the agent's Band handle (owner/slug) — used to @mention it.
agents:
  triage:
    account: primary
    framework: langgraph
    handle:   "@youraccount/triage"
    agent_id: "REPLACE_WITH_TRIAGE_UUID"
    api_key:  "REPLACE_WITH_TRIAGE_API_KEY"

  threat_intel:
    account: primary
    framework: langgraph  # band-sdk 0.2.11 has no OpenAI adapter; see pyproject
    handle:   "@youraccount/threat-intel"
    agent_id: "REPLACE_WITH_THREAT_INTEL_UUID"
    api_key:  "REPLACE_WITH_THREAT_INTEL_API_KEY"

  compliance:
    account: secondary
    framework: pydantic_ai
    handle:   "@yoursecondaccount/compliance"
    agent_id: "REPLACE_WITH_COMPLIANCE_UUID"
    api_key:  "REPLACE_WITH_COMPLIANCE_API_KEY"

  commander:
    account: primary
    framework: anthropic
    handle:   "@youraccount/commander"
    agent_id: "REPLACE_WITH_COMMANDER_UUID"
    api_key:  "REPLACE_WITH_COMMANDER_API_KEY"

  # Facilitator: a SILENT anti-stall watchdog (no agent loop, no LLM).
  # scripts/incident_driver.py uses this key to read the incident transcript and
  # post nudges @mentioning whoever should act next. Triage adds it to every
  # incident room. Register it as a normal External Agent on the PRIMARY account.
  facilitator:
    account: primary
    framework: none
    handle:   "@youraccount/facilitator"
    agent_id: "REPLACE_WITH_FACILITATOR_UUID"
    api_key:  "REPLACE_WITH_FACILITATOR_API_KEY"

# The incident war room. Create a fresh room per run containing the human (CISO)
# + Triage and paste its id here (or pass --room / set BAND_ROOM_ID). The
# injector posts the alert here; Triage recruits the specialists into it.
room:
  default_room_id: ""